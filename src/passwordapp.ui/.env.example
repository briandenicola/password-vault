VUE_APP_TITLE="Password Vault"
VUE_APP_REQUIRES_AUTHENTICATION=false
VUE_APP_REQUIRES_APP_INSIGHTS=false
VUE_APP_INSIGHTS_CONNECTION_STRING=""
VUE_APP_API_ENDPOINT="http://localhost:7071"

# OFF-4 (E2EE) client-side encryption is off by default.
VUE_APP_E2EE=false
# WebAuthn RP ID for E2EE passkeys. Production vault.denicolafamily.com uses
# denicolafamily.com so passkeys survive subdomain / URL changes.
VUE_APP_RP_ID=denicolafamily.com
